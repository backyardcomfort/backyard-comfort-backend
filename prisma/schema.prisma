// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User Models
model User {
  id                    String                    @id @default(cuid())
  email                 String                    @unique
  password              String
  firstName             String?
  lastName              String?
  avatar                String?
  phone                 String?
  role                  String                    @default("customer") // customer, admin, affiliate, vendor
  status                String                    @default("active") // active, inactive, suspended
  emailVerified         Boolean                   @default(false)
  phoneVerified         Boolean                   @default(false)
  twoFactorEnabled      Boolean                   @default(false)
  twoFactorSecret       String?
  lastLoginAt           DateTime?
  loginAttempts         Int                       @default(0)
  lastLoginAttemptAt    DateTime?
  createdAt             DateTime                  @default(now())
  updatedAt             DateTime                  @updatedAt

  // Relations
  profile               UserProfile?
  addresses             Address[]
  orders                Order[]
  wishlist              Wishlist[]
  reviews               Review[]
  memberships           Membership[]
  subscriptions         Subscription[]
  affiliateAccount      Affiliate?
  aiSetups              AiSetup[]
  bundles               Bundle[]
  supportTickets        SupportTicket[]
  auditLogs             AuditLog[]
  emailPreferences      EmailPreference?
  smsPreferences        SmsPreference?

  @@index([email])
  @@index([role])
  @@index([status])
}

model UserProfile {
  id                    String                    @id @default(cuid())
  userId                String                    @unique
  bio                   String?
  avatar                String?
  preferredCurrency     String                    @default("USD")
  preferredLanguage     String                    @default("en")
  timezone              String?
  gdprConsent           Boolean                   @default(false)
  marketingConsent      Boolean                   @default(false)
  analyticsConsent      Boolean                   @default(false)
  createdAt             DateTime                  @default(now())
  updatedAt             DateTime                  @updatedAt

  user                  User                      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Address {
  id                    String                    @id @default(cuid())
  userId                String
  type                  String                    @default("shipping") // shipping, billing
  street                String
  city                  String
  state                 String?
  country               String
  postalCode            String
  isDefault             Boolean                   @default(false)
  createdAt             DateTime                  @default(now())
  updatedAt             DateTime                  @updatedAt

  user                  User                      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Product Models
model Product {
  id                    String                    @id @default(cuid())
  sku                   String                    @unique
  name                  String
  slug                  String                    @unique
  description           String                    @db.Text
  shortDescription      String?
  category              String
  subcategory           String?
  images                String[]                  @default([])
  thumbnail             String?
  price                 Decimal                   @db.Decimal(10, 2)
  cost                  Decimal                   @db.Decimal(10, 2)              // Server-side only, never public
  salePrice             Decimal?                  @db.Decimal(10, 2)
  stock                 Int                       @default(0)
  weight                Decimal?                  @db.Decimal(10, 2)
  dimensions            String?                   // JSON stored as string
  isActive              Boolean                   @default(true)
  isFeatured            Boolean                   @default(false)
  rating                Decimal?                  @db.Decimal(3, 2)
  reviewCount           Int                       @default(0)
  tags                  String[]                  @default([])
  seoTitle              String?
  seoDescription        String?
  seoKeywords           String[]                  @default([])
  createdAt             DateTime                  @default(now())
  updatedAt             DateTime                  @updatedAt

  // Relations
  orderItems            OrderItem[]
  bundleItems           BundleItem[]
  reviews               Review[]
  wishlistItems         Wishlist[]
  affiliate             AffiliateProduct[]
  aiRecommendations     AiRecommendation[]
  subscriptionItems     SubscriptionItem[]

  @@index([category])
  @@index([isActive])
  @@index([isFeatured])
}

model Category {
  id                    String                    @id @default(cuid())
  name                  String                    @unique
  slug                  String                    @unique
  description           String?
  image                 String?
  icon                  String?
  parent                String?
  order                 Int                       @default(0)
  createdAt             DateTime                  @default(now())
  updatedAt             DateTime                  @updatedAt

  @@index([slug])
}

// Order Models
model Order {
  id                    String                    @id @default(cuid())
  orderNumber           String                    @unique
  userId                String
  status                String                    @default("pending") // pending, paid, processing, shipped, delivered, cancelled, refunded
  paymentStatus         String                    @default("pending") // pending, completed, failed, refunded
  shippingStatus        String                    @default("pending") // pending, processing, shipped, delivered
  subtotal              Decimal                   @db.Decimal(10, 2)
  shippingCost          Decimal                   @db.Decimal(10, 2) @default(0)
  tax                   Decimal                   @db.Decimal(10, 2) @default(0)
  discount              Decimal                   @db.Decimal(10, 2) @default(0)
  total                 Decimal                   @db.Decimal(10, 2)
  currency              String                    @default("USD")
  couponCode            String?
  shippingAddress       String                    @db.Text
  billingAddress        String                    @db.Text
  notes                 String?
  createdAt             DateTime                  @default(now())
  updatedAt             DateTime                  @updatedAt
  paidAt                DateTime?
  shippedAt             DateTime?
  deliveredAt           DateTime?
  cancelledAt           DateTime?

  // Relations
  user                  User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  items                 OrderItem[]
  payment               PayPalTransaction?
  refund                Refund?
  auditLogs             AuditLog[]

  @@index([userId])
  @@index([status])
  @@index([orderNumber])
}

model OrderItem {
  id                    String                    @id @default(cuid())
  orderId               String
  productId             String
  quantity              Int
  price                 Decimal                   @db.Decimal(10, 2)
  discount              Decimal                   @db.Decimal(10, 2) @default(0)
  total                 Decimal                   @db.Decimal(10, 2)
  createdAt             DateTime                  @default(now())
  updatedAt             DateTime                  @updatedAt

  // Relations
  order                 Order                     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product               Product                   @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
}

// Bundle Models
model Bundle {
  id                    String                    @id @default(cuid())
  slug                  String                    @unique
  name                  String
  description           String                    @db.Text
  image                 String?
  basePrice             Decimal                   @db.Decimal(10, 2)
  bundlePrice           Decimal                   @db.Decimal(10, 2)
  discount              Decimal?                  @db.Decimal(10, 2)
  tier                  String                    @default("standard") // essentials, comfort, premium, budget-friendly
  isActive              Boolean                   @default(true)
  isFeatured            Boolean                   @default(false)
  createdBy             String
  createdAt             DateTime                  @default(now())
  updatedAt             DateTime                  @updatedAt

  // Relations
  items                 BundleItem[]
  user                  User                      @relation(fields: [createdBy], references: [id])
  starterKits           StarterKit[]

  @@index([isActive])
  @@index([createdBy])
}

model BundleItem {
  id                    String                    @id @default(cuid())
  bundleId              String
  productId             String
  quantity              Int                       @default(1)
  reason                String?                   // Why this product is recommended
  createdAt             DateTime                  @default(now())

  // Relations
  bundle                Bundle                    @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  product               Product                   @relation(fields: [productId], references: [id])

  @@unique([bundleId, productId])
  @@index([bundleId])
  @@index([productId])
}

model StarterKit {
  id                    String                    @id @default(cuid())
  slug                  String                    @unique
  name                  String
  description           String                    @db.Text
  image                 String?
  category              String                    // Van Life, Backyard, RV, etc.
  tier                  String                    // low, mid, premium
  basePrice             Decimal                   @db.Decimal(10, 2)
  bundlePrice           Decimal                   @db.Decimal(10, 2)
  isActive              Boolean                   @default(true)
  createdAt             DateTime                  @default(now())
  updatedAt             DateTime                  @updatedAt

  // Relations
  bundle                Bundle                    @relation(fields: [slug], references: [slug])

  @@index([category])
  @@index([tier])
}

// Wishlist
model Wishlist {
  id                    String                    @id @default(cuid())
  userId                String
  productId             String
  createdAt             DateTime                  @default(now())

  // Relations
  user                  User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  product               Product                   @relation(fields: [productId], references: [id])

  @@unique([userId, productId])
  @@index([userId])
}

// Review Models
model Review {
  id                    String                    @id @default(cuid())
  productId             String
  userId                String
  rating                Int                       // 1-5
  title                 String?
  content               String                    @db.Text
  verified              Boolean                   @default(false)
  helpful               Int                       @default(0)
  unhelpful             Int                       @default(0)
  createdAt             DateTime                  @default(now())
  updatedAt             DateTime                  @updatedAt

  // Relations
  product               Product                   @relation(fields: [productId], references: [id], onDelete: Cascade)
  user                  User                      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([userId])
}

// Membership Models
model Membership {
  id                    String                    @id @default(cuid())
  userId                String
  tier                  String                    @default("free") // free, premium
  status                String                    @default("active")
  joinedAt              DateTime                  @default(now())
  renewalDate           DateTime?
  expiresAt             DateTime?
  createdAt             DateTime                  @default(now())
  updatedAt             DateTime                  @updatedAt

  // Relations
  user                  User                      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId])
  @@index([tier])
}

// Subscription Models
model Subscription {
  id                    String                    @id @default(cuid())
  userId                String
  name                  String                    // Monthly Gear Box, etc.
  status                String                    @default("active") // active, paused, cancelled
  frequency             String                    @default("monthly") // monthly, quarterly
  amount                Decimal                   @db.Decimal(10, 2)
  currency              String                    @default("USD")
  nextBillingDate       DateTime
  lastBillingDate       DateTime?
  cancellationDate      DateTime?
  createdAt             DateTime                  @default(now())
  updatedAt             DateTime                  @updatedAt

  // Relations
  user                  User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  items                 SubscriptionItem[]

  @@index([userId])
  @@index([status])
}

model SubscriptionItem {
  id                    String                    @id @default(cuid())
  subscriptionId        String
  productId             String
  quantity              Int                       @default(1)
  createdAt             DateTime                  @default(now())

  // Relations
  subscription          Subscription              @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  product               Product                   @relation(fields: [productId], references: [id])

  @@index([subscriptionId])
}

// Coupon/Discount Models
model Coupon {
  id                    String                    @id @default(cuid())
  code                  String                    @unique
  description           String?
  discountType          String                    @default("percentage") // percentage, fixed
  discountValue         Decimal                   @db.Decimal(10, 2)
  maxUses               Int?
  usedCount             Int                       @default(0)
  minOrderAmount        Decimal?                  @db.Decimal(10, 2)
  applicableCategories  String[]                  @default([])
  startDate             DateTime
  endDate               DateTime
  isActive              Boolean                   @default(true)
  createdAt             DateTime                  @default(now())
  updatedAt             DateTime                  @updatedAt

  @@index([code])
  @@index([isActive])
}

model GiftCard {
  id                    String                    @id @default(cuid())
  code                  String                    @unique
  amount                Decimal                   @db.Decimal(10, 2)
  balance               Decimal                   @db.Decimal(10, 2)
  purchasedBy           String?
  redeemedBy            String?
  isActive              Boolean                   @default(true)
  expiresAt             DateTime?
  createdAt             DateTime                  @default(now())
  redeemedAt            DateTime?

  @@index([code])
  @@index([isActive])
}

// Payment Models
model PayPalTransaction {
  id                    String                    @id @default(cuid())
  orderId               String                    @unique
  paypalOrderId         String                    @unique
  paypalTransactionId   String?
  status                String                    @default("pending") // pending, completed, failed, cancelled
  amount                Decimal                   @db.Decimal(10, 2)
  currency              String                    @default("USD")
  payer                 String                    @db.Text // JSON
  details               String                    @db.Text // JSON
  webhookData           String?                   @db.Text // JSON
  verifiedAt            DateTime?
  createdAt             DateTime                  @default(now())
  updatedAt             DateTime                  @updatedAt

  // Relations
  order                 Order                     @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([paypalOrderId])
  @@index([status])
}

model WebhookEvent {
  id                    String                    @id @default(cuid())
  provider              String                    // paypal, stripe, etc.
  eventType             String
  externalId            String
  payload               String                    @db.Text
  processed             Boolean                   @default(false)
  processedAt           DateTime?
  error                 String?
  retryCount            Int                       @default(0)
  createdAt             DateTime                  @default(now())

  @@index([provider])
  @@index([processed])
  @@index([createdAt])
}

model Refund {
  id                    String                    @id @default(cuid())
  orderId               String                    @unique
  amount                Decimal                   @db.Decimal(10, 2)
  reason                String
  status                String                    @default("pending") // pending, completed, failed
  paypalRefundId        String?
  createdAt             DateTime                  @default(now())
  updatedAt             DateTime                  @updatedAt

  // Relations
  order                 Order                     @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

// Affiliate Models
model Affiliate {
  id                    String                    @id @default(cuid())
  userId                String                    @unique
  affiliateCode         String                    @unique
  platform              String                    // amazon, impact, sharesale
  status                String                    @default("pending") // pending, approved, rejected, suspended
  totalCommissions      Decimal                   @db.Decimal(12, 2) @default(0)
  paidCommissions       Decimal                   @db.Decimal(12, 2) @default(0)
  pendingCommissions    Decimal                   @db.Decimal(12, 2) @default(0)
  approvedAt            DateTime?
  payoutDetails         String?                   @db.Text // JSON
  createdAt             DateTime                  @default(now())
  updatedAt             DateTime                  @updatedAt

  // Relations
  user                  User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  products              AffiliateProduct[]
  transactions          AffiliateTransaction[]

  @@index([status])
}

model AffiliateProduct {
  id                    String                    @id @default(cuid())
  affiliateId           String
  productId             String
  url                   String
  commission            Decimal                   @db.Decimal(5, 2) // percentage
  clicks                Int                       @default(0)
  conversions           Int                       @default(0)
  createdAt             DateTime                  @default(now())

  // Relations
  affiliate             Affiliate                 @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
  product               Product                   @relation(fields: [productId], references: [id])

  @@unique([affiliateId, productId])
  @@index([affiliateId])
}

model AffiliateTransaction {
  id                    String                    @id @default(cuid())
  affiliateId           String
  orderId               String?
  amount                Decimal                   @db.Decimal(10, 2)
  status                String                    @default("pending") // pending, approved, paid
  transactionDate       DateTime
  payoutDate            DateTime?
  createdAt             DateTime                  @default(now())

  // Relations
  affiliate             Affiliate                 @relation(fields: [affiliateId], references: [id], onDelete: Cascade)

  @@index([affiliateId])
  @@index([status])
}

// AI Models
model AiSetup {
  id                    String                    @id @default(cuid())
  userId                String
  title                 String?
  useCase               String                    // Van, RV, Backyard, Camping, Off-Grid, Outdoor Cooking, Preparedness
  budget                Decimal                   @db.Decimal(10, 2)
  experienceLevel       String                    // beginner, intermediate, expert
  climate               String?
  spaceSize             String?
  goals                 String[]                  @default([])
  essentials            String                    @db.Text // JSON array of product IDs
  upgrades              String                    @db.Text // JSON array
  premiumUpgrades       String                    @db.Text // JSON array
  budgetAlternatives    String                    @db.Text // JSON array
  totalCost             Decimal                   @db.Decimal(10, 2)
  isSaved               Boolean                   @default(false)
  createdAt             DateTime                  @default(now())
  updatedAt             DateTime                  @updatedAt

  // Relations
  user                  User                      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model AiRecommendation {
  id                    String                    @id @default(cuid())
  productId             String
  reason                String                    @db.Text
  relevanceScore        Decimal?                  @db.Decimal(3, 2)
  category              String
  tier                  String                    // essentials, upgrades, premium
  createdAt             DateTime                  @default(now())

  // Relations
  product               Product                   @relation(fields: [productId], references: [id])

  @@index([productId])
  @@index([tier])
}

// Content Models
model BlogPost {
  id                    String                    @id @default(cuid())
  slug                  String                    @unique
  title                 String
  excerpt               String?
  content               String                    @db.Text
  author                String?
  image                 String?
  status                String                    @default("draft") // draft, published
  categories            String[]                  @default([])
  tags                  String[]                  @default([])
  seoTitle              String?
  seoDescription        String?
  seoKeywords           String[]                  @default([])
  viewCount             Int                       @default(0)
  publishedAt           DateTime?
  createdAt             DateTime                  @default(now())
  updatedAt             DateTime                  @updatedAt

  @@index([slug])
  @@index([status])
}

model ContentVault {
  id                    String                    @id @default(cuid())
  type                  String                    // image, video, document, social
  name                  String
  url                   String
  size                  Int?
  mimeType              String?
  tags                  String[]                  @default([])
  createdAt             DateTime                  @default(now())

  @@index([type])
}

// Support Models
model SupportTicket {
  id                    String                    @id @default(cuid())
  ticketNumber          String                    @unique
  userId                String
  subject               String
  message               String                    @db.Text
  status                String                    @default("open") // open, in_progress, resolved, closed
  priority              String                    @default("normal") // low, normal, high, urgent
  responses             String[]                  @default([]) // JSON array
  createdAt             DateTime                  @default(now())
  updatedAt             DateTime                  @updatedAt
  resolvedAt            DateTime?

  // Relations
  user                  User                      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

// Notification Models
model Notification {
  id                    String                    @id @default(cuid())
  userId                String?
  type                  String                    // order, promotion, system
  title                 String
  message               String
  link                  String?
  read                  Boolean                   @default(false)
  createdAt             DateTime                  @default(now())

  @@index([userId])
  @@index([read])
}

model EmailPreference {
  id                    String                    @id @default(cuid())
  userId                String                    @unique
  marketingEmails       Boolean                   @default(true)
  productUpdates        Boolean                   @default(true)
  promotions            Boolean                   @default(true)
  newsletters           Boolean                   @default(true)
  abandonedCart         Boolean                   @default(true)
  createdAt             DateTime                  @default(now())
  updatedAt             DateTime                  @updatedAt

  user                  User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SmsPreference {
  id                    String                    @id @default(cuid())
  userId                String                    @unique
  cartRecovery          Boolean                   @default(true)
  shipping              Boolean                   @default(true)
  promotions            Boolean                   @default(false)
  createdAt             DateTime                  @default(now())
  updatedAt             DateTime                  @updatedAt

  user                  User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Audit Log Models
model AuditLog {
  id                    String                    @id @default(cuid())
  userId                String?
  action                String
  entity                String
  entityId              String
  orderId               String?
  changes               String?                   @db.Text // JSON
  ipAddress             String?
  userAgent             String?
  createdAt             DateTime                  @default(now())

  // Relations
  user                  User?                     @relation(fields: [userId], references: [id], onDelete: SetNull)
  order                 Order?                    @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([entityId])
  @@index([createdAt])
}
